# Required: Supabase client config
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for support/outreach email sending
# EMAIL_PROVIDER: resend | m365 | smtp | manual
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM=Rivet <onboarding@resend.dev>
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_SENDER_UPN=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Required for absolute links in emails (prod domain)
NEXT_PUBLIC_APP_URL=

# Optional: only for privileged server-side jobs/scripts
SUPABASE_SERVICE_ROLE_KEY=

# Monitoring/alerting (optional but recommended for prod)
CRON_SECRET=
MONITOR_TEAMS_WEBHOOK_URL=
MONITOR_ALERT_EMAIL_TO=

# Optional: regulation automation source overrides
REACH_RELEASES_FEED_URL=
ROHS_RELEASES_FEED_URL=

# Required for AI-assisted OEM contact verification
ANTHROPIC_API_KEY=
