# Required: Supabase client config
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for support/outreach email sending
RESEND_API_KEY=
RESEND_FROM=Rivet <onboarding@resend.dev>

# Required for absolute links in emails (prod domain)
NEXT_PUBLIC_APP_URL=

# Optional: only for privileged server-side jobs/scripts
SUPABASE_SERVICE_ROLE_KEY=

# Monitoring/alerting (optional but recommended for prod)
CRON_SECRET=
MONITOR_TEAMS_WEBHOOK_URL=
MONITOR_ALERT_EMAIL_TO=
